generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Group {
  id           String   @id @default(uuid())
  name         String   @unique
  displayOrder Int      @map("display_order")
  teams        Team[]
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("groups")
}

model Team {
  id             String   @id @default(uuid())
  name           String   @unique
  slug           String   @unique
  fifaCode       String   @unique @map("fifa_code")
  badgeUrl       String?  @map("badge_url")
  colorPrimary   String   @map("color_primary")
  colorSecondary String   @map("color_secondary")
  groupId        String   @map("group_id")
  group          Group    @relation(fields: [groupId], references: [id])
  players        Player[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("teams")
}

model Club {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  countryCode String   @map("country_code") @db.Char(3)
  badgeUrl    String?  @map("badge_url")
  players     Player[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("clubs")
}

model Player {
  id            String   @id @default(uuid())
  name          String
  canonicalName String   @map("canonical_name")
  albumCode     String?  @map("album_code")
  inAlbum       Boolean  @default(false) @map("in_album")
  calledUp      Boolean  @default(false) @map("called_up")
  teamId        String   @map("team_id")
  team          Team     @relation(fields: [teamId], references: [id])
  clubId        String?  @map("club_id")
  club          Club?    @relation(fields: [clubId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("players")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  role          String         @default("admin")
  refreshTokens RefreshToken[]
  userStickers  UserSticker[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model UserSticker {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  albumCode String   @map("album_code")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, albumCode])
  @@map("user_stickers")
}
